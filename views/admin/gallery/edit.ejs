<%- include("../../layouts/admin-header") %>

<div class="card shadow p-4">

    <h2 class="mb-4">Edit Gallery Image</h2>

    <form action="/admin/gallery/update/<%= gallery._id %>"
          method="POST">

        <div class="mb-3">

            <label class="form-label">
                Image Title
            </label>

            <input type="text"
                   name="title"
                   value="<%= gallery.title %>"
                   class="form-control"
                   required>

        </div>

        <div class="mb-3">

            <label class="form-label">
                Current Image
            </label>

            <br>

            <img src="/uploads/gallery/<%= gallery.image %>"
                 width="250"
                 class="img-thumbnail">

        </div>

        <button type="submit"
                class="btn btn-primary">

            Update Image

        </button>

        <a href="/admin/gallery"
           class="btn btn-secondary">

            Back

        </a>

    </form>

</div>

<%- include("../../layouts/admin-footer") %>