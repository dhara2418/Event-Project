<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wedding Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <style>
        body {
            background: #f8f9fa;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #1f2937;
            position: fixed;
            left: 0;
            top: 0;
            padding-top: 20px;
        }

        .sidebar h3 {
            color: white;
            text-align: center;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            color: #d1d5db;
            text-decoration: none;
            padding: 15px 25px;
            transition: .3s;
        }

        .sidebar a:hover {
            background: #374151;
            color: white;
        }

        .main {
            margin-left: 260px;
            padding: 30px;
        }

        .card-box {
            border-radius: 15px;
            color: white;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,.1);
        }

        .gallery-card {
            background: linear-gradient(45deg,#6366f1,#8b5cf6);
        }

        .event-card {
            background: linear-gradient(45deg,#06b6d4,#3b82f6);
        }

        .rsvp-card {
            background: linear-gradient(45deg,#10b981,#22c55e);
        }

        .guest-card {
            background: linear-gradient(45deg,#f97316,#ef4444);
        }

        .card-box i {
            font-size: 40px;
        }

        .count {
            font-size: 35px;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <h3>Wedding Admin</h3>

        <a href="/admin/dashboard">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="/admin/gallery">
            <i class="bi bi-images"></i> Gallery
        </a>

        <a href="/admin/events">
            <i class="bi bi-calendar-event"></i> Events
        </a>

        <a href="/admin/rsvp">
            <i class="bi bi-envelope-heart"></i> RSVP
        </a>

        <a href="/admin/guests">
            <i class="bi bi-people"></i> Guests
        </a>
    </div>

    <div class="main">

        <h2 class="mb-4">Dashboard Overview</h2>

        <div class="row g-4">

            <div class="col-md-3">
                <div class="card-box gallery-card">
                    <i class="bi bi-images"></i>
                    <h5 class="mt-3">Gallery</h5>
                    <div class="count"><%= galleryCount %></div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box event-card">
                    <i class="bi bi-calendar-event"></i>
                    <h5 class="mt-3">Events</h5>
                    <div class="count"><%= eventCount %></div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box rsvp-card">
                    <i class="bi bi-envelope-heart"></i>
                    <h5 class="mt-3">RSVP</h5>
                    <div class="count"><%= rsvpCount %></div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box guest-card">
                    <i class="bi bi-people"></i>
                    <h5 class="mt-3">Guests</h5>
                    <div class="count"><%= guestCount %></div>
                </div>
            </div>

        </div>

    </div>

</body>

</html>